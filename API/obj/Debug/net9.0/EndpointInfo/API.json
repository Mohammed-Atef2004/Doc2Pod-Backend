{
  "openapi": "3.0.4",
  "info": {
    "title": "API",
    "version": "1.0"
  },
  "paths": {
    "/api/documents/upload": {
      "post": {
        "tags": [
          "Document"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "File": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              },
              "encoding": {
                "File": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/podcast/generate": {
      "post": {
        "tags": [
          "Podcast"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GeneratePodcastCommand"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/GeneratePodcastCommand"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/GeneratePodcastCommand"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/podcast/{id}": {
      "get": {
        "tags": [
          "Podcast"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GeneratePodcastCommand": {
        "type": "object",
        "properties": {
          "documentId": {
            "type": "string",
            "format": "uuid"
          },
          "mode": {
            "$ref": "#/components/schemas/PodcastMode"
          },
          "topic": {
            "type": "string",
            "nullable": true
          },
          "startPage": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "endPage": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PodcastMode": {
        "enum": [
          1,
          2,
          3
        ],
        "type": "integer",
        "format": "int32"
      }
    }
  },
  "tags": [
    {
      "name": "Document"
    },
    {
      "name": "Podcast"
    }
  ]
}